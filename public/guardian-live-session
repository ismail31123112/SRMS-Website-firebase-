        body.innerHTML = `<div style="text-align:center; padding:20px;"><p style="color:var(--text-muted); font-weight:600; font-size:15px;">No active meetings currently.</p></div>`; 
    } catch (e) { body.innerHTML = `<p style="color:red; text-align:center;">Connection error.</p>`; }
  }

  function joinMeet() {
    const config = `#config.startWithAudioMuted=true&config.prejoinPageEnabled=false&userInfo.displayName="Guardian of ${std.name}"`;
    window.open(`https://meet.jit.si/SRMS-Live-Guardian${config}`, '_blank');
    closeModal('liveClassModal');
  }

  function openFeesModal() {
    document.getElementById('feesModal').style.display = 'flex';
    let total = 0; let pendingCount = 0; let html = `<h3 style="margin:0 0 20px 0; color:var(--primary); font-size:20px; border-bottom:2px solid #f1f5f9; padding-bottom:15px;">Billing Hub</h3><div style="background:#f8fafc; padding:20px; border-radius:16px; border:1px solid #e2e8f0;">`;
    
    let genAmt = parseFloat(std.schoolFeeDue) || 0; let genSts = (std.schoolFeeStatus || "").toLowerCase();
    if(genAmt > 0 && genSts !== "paid") { 
        if(genSts === "pending") { pendingCount++; html += `<div style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:15px; color:var(--text-main);"><span>School Fee</span><b style="color:#d97706;">Pending Review ⏳</b></div>`; }
        else { total += genAmt; html += `<div style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:15px; color:var(--text-main);"><span>School Fee</span><b style="color:var(--primary);">${genAmt} Tk</b></div>`; }
    }

    let hosAmt = parseFloat(std.hostelFeeDue) || 0; let hosSts = (std.hostelFeeStatus || "").toLowerCase();
    if(hosAmt > 0 && hosSts !== "paid") { 
        if(hosSts === "pending") { pendingCount++; html += `<div style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:15px; color:var(--text-main);"><span>Hostel Fee</span><b style="color:#d97706;">Pending Review ⏳</b></div>`; }
        else { total += hosAmt; html += `<div style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:15px; color:var(--text-main);"><span>Hostel Fee</span><b style="color:var(--primary);">${hosAmt} Tk</b></div>`; }
    }

    if(std.customFees && std.customFees.length > 0) {
        std.customFees.forEach(cf => { 
            let cAmt = parseFloat(cf.amount) || 0; let cSts = (cf.status || "").toLowerCase();
            if(cAmt > 0 && cSts !== "paid") { 
                if(cSts === "pending") { pendingCount++; html += `<div style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:15px; color:var(--text-main);"><span>${sanitizeHTML(cf.name)}</span><b style="color:#d97706;">Pending Review ⏳</b></div>`; }
                else { total += cAmt; html += `<div style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:15px; color:var(--text-main);"><span>${sanitizeHTML(cf.name)}</span><b style="color:var(--primary);">${cAmt} Tk</b></div>`; }
            }
        });
    }
    html += `</div>`;
    
    if(total > 0) {
        html += `<div style="margin-top:25px; text-align:center; background:#fff1f2; padding:20px; border-radius:16px;">
                    <p style="margin:0 0 5px 0; color:var(--text-muted); font-size:13px; font-weight:600;">Total Payable Amount</p>
                    <h2 style="margin:0; color:var(--danger); font-size:32px;">${total} Tk</h2>
                 </div>
                 <div style="margin-top:20px;">
                    <label style="font-size:12px; font-weight:700; color:var(--text-muted);">Mobile Number (For Payment)</label>
                    <input type="text" id="feesPhone" value="${sanitizeHTML(std.phone) || ''}" placeholder="Enter Bkash/Nagad Number">
                 </div>
                 <p style="font-size:12px; color:var(--danger); font-weight:700; text-align:center; margin-top:12px; line-height:1.4;">⚠️ Note: If your transaction shows "Pending" in gateway, please do NOT pay again. We will verify manually.</p>
                 <button id="btnPayNow" class="login-btn" style="background:var(--danger); font-size:15px;" onclick="generatePaymentLink()">PROCEED TO SECURE PAYMENT</button>
                 <a id="feesPayLink" href="#" target="_blank" class="login-btn" style="display:none; background:#059669; font-size:15px; text-align:center;">✅ CLICK HERE TO PAY</a>
                 <div id="feesMsg" style="margin-top:15px; font-size:13px; font-weight:bold; text-align:center;"></div>`;
    } else if (pendingCount > 0) {
        html += `<div style="text-align:center; color:#d97706; font-weight:700; padding:30px; background:#fef3c7; border-radius:16px; margin-top:20px; border:1px solid #fde68a;">⏳ Your child's payment is currently under Pending Review. We will update it soon.</div>`;
    } else { 
        html += `<div style="text-align:center; color:#059669; font-weight:700; padding:30px; background:#f0fdf4; border-radius:16px; margin-top:20px; border:1px solid #a7f3d0;">✅ All Fees Already Paid. Thank You!</div>`; 
    }
    document.getElementById('feesModalBody').innerHTML = html; 
  }

  function generatePaymentLink() {
    const phone = sanitizeHTML(document.getElementById("feesPhone").value.trim());
    if (phone.length < 11) { document.getElementById("feesMsg").innerHTML = "<span style='color:var(--danger);'>⚠️ সঠিক মোবাইল নম্বর দিন।</span>"; return; }
    
    const btn = document.getElementById("btnPayNow");
    btn.innerHTML = "<span class='loader-spinner' style='border-top-color:#fff;'></span> Connecting Server..."; btn.disabled = true;
    
    const url = FEE_PAY_SCRIPT + "?action=create_payment&student_id=" + encodeURIComponent(std.id) + "&phone=" + encodeURIComponent(phone) + "&email=" + encodeURIComponent(std.email || '');
    
    fetch(url).then(r => r.json()).then(data => {
        if (data.payment_url) { 
            btn.style.display = "none"; 
            const linkBtn = document.getElementById("feesPayLink"); 
            linkBtn.style.display = "block"; linkBtn.href = sanitizeHTML(data.payment_url); 
            document.getElementById("feesMsg").innerHTML = "";
        } else { btn.innerHTML = "Retry Payment"; btn.disabled = false; document.getElementById("feesMsg").innerHTML = "<span style='color:var(--danger);'>Payment generation failed.</span>"; }
    }).catch(e => { btn.innerHTML = "Retry Payment"; btn.disabled = false; document.getElementById("feesMsg").innerHTML = "<span style='color:var(--danger);'>Network Error.</span>"; });
  }

  function openSecurityModal() {
    document.getElementById('newPass').value = "";
    document.getElementById('passMsg').innerText = "";
    document.getElementById('securityModal').style.display = 'flex';
  }

  async function updatePassword() {
    const p = document.getElementById('newPass').value; 
    const msgBox = document.getElementById('passMsg');
    const btn = document.getElementById('btnUpdateSecurity');
    
    if(!p || p.length < 6) { 
        msgBox.style.color = "var(--danger)"; 
        msgBox.innerText = "Password must be at least 6 characters."; 
        return; 
    }
    
    let docId = sessionStorage.getItem('srms_student_docId');
    if(!docId) return;

    msgBox.style.color = "var(--primary)";
    msgBox.innerText = "Updating...";
    btn.innerHTML = "<span class='loader-spinner' style='border-top-color:#fff;'></span> SAVING..."; btn.disabled = true;
    
    try { 
        // Using the newly implemented secure backend approach
        const res = await fetch(SCRIPT_URL, {
            method: "POST",
            headers: { "Content-Type": "text/plain;charset=utf-8" },
            body: JSON.stringify({ action: "updatePassword", docId: docId, newPass: p })
        });
        const data = await res.json();
        
        if(data.status === "success") {
            msgBox.style.color = "#059669"; 
            msgBox.innerText = `✅ ${sanitizeHTML(data.message || "Password Changed Successfully!")}`; 
            document.getElementById('newPass').value = "";
        } else {
            msgBox.style.color = "var(--danger)"; 
            msgBox.innerText = sanitizeHTML(data.message || "Error updating password.");
        }
    } catch(e) { 
        msgBox.style.color = "var(--danger)"; 
        msgBox.innerText = "Error! Please check your network and try again."; 
    }
    btn.innerHTML = "SAVE NEW PASSWORD"; btn.disabled = false;
  }
</script>

