  async function requestOTP() {
    const id = sanitizeHTML(document.getElementById('fpID').value.trim());
    if(!id) { document.getElementById('fpMsg').innerHTML = `<span style="color:var(--danger);">Please enter Student ID.</span>`; return; }
    
    const btn = document.getElementById('btnRequestOTP');
    btn.innerHTML = "<span class='loader-spinner' style='border-top-color:#fff;'></span> SENDING..."; btn.disabled = true;
    
    try {
        const res = await fetch(SCRIPT_URL, { 
            method: "POST", 
            headers: { "Content-Type": "text/plain;charset=utf-8" },
            body: JSON.stringify({ action: "sendOTP", id: id }) 
        });
        
        const textResponse = await res.text();
        const data = JSON.parse(textResponse);
        
        if(data.status === "success") {
            // New Secure Logic: Save docId, OTP is verified only on backend
            resettingStudentID = id;
            resettingDocId = data.docId; 
            document.getElementById('fpStep1').style.display = 'none';
            document.getElementById('fpStep2').style.display = 'block';
            let sMsg = data.msg || data.message || (data.email ? `OTP sent to ${data.email}` : "OTP Sent Successfully!");
            document.getElementById('fpMsg').innerHTML = `<span style="color:#059669;"><b>${sanitizeHTML(sMsg)}</b></span>`;
        } else {
            let eMsg = data.message || data.msg || "Error finding student.";
            document.getElementById('fpMsg').innerHTML = `<span style="color:var(--danger);">${sanitizeHTML(eMsg)}</span>`;
        }
    } catch(e) { document.getElementById('fpMsg').innerHTML = `<span style="color:var(--danger);">Network Error! Try again.</span>`; }
    btn.innerHTML = "SEND OTP TO EMAIL"; btn.disabled = false;
  }

