          allAttendanceData = {}; 
          
          if (data && data.length > 0 && data[0].document) {
              data.forEach(item => {
                  if(item.document && item.document.fields) {
                      let f = item.document.fields;
                      let pDate = sanitizeHTML(f.pureDate?.stringValue || ""); 
                      let timeStr = sanitizeHTML(f.time?.stringValue || "");
                      let type = sanitizeHTML(f.type?.stringValue || ""); 
                      
                      if(pDate) {
                          let monthYear = pDate.substring(0, 7); 
                          
                          if(!allAttendanceData[monthYear]) {
                              allAttendanceData[monthYear] = { dates: {} };
                          }
                          if(!allAttendanceData[monthYear].dates[pDate]) {
                              allAttendanceData[monthYear].dates[pDate] = { in: "<span style='color:#94a3b8;'>--</span>", out: "<span style='color:#94a3b8;'>--</span>" };
                          }
                          
                          if(type === "IN") allAttendanceData[monthYear].dates[pDate].in = timeStr;
                          if(type === "OUT") allAttendanceData[monthYear].dates[pDate].out = timeStr;
                      }
                  }
              });
          }
          populateAttendanceMonths();
      } catch(e) {
          console.error(e);
          document.getElementById('modalAttTableBody').innerHTML = '<tr><td colspan="3" style="text-align:center; padding:15px; color:var(--danger); font-weight:bold;">Failed to load attendance history.</td></tr>';
      }
      document.getElementById('attLoader').style.display = 'none';
  }

  function populateAttendanceMonths() {
      let select = document.getElementById('attMonthFilter');
      select.innerHTML = "";
      
      let months = Object.keys(allAttendanceData).sort().reverse();
      
      if(months.length === 0) {
          select.innerHTML = "<option value=''>No Attendance Data Found</option>";
          renderAttendanceTable("");
          return;
      }
      
      months.forEach(m => {
          let dateObj = new Date(m + "-01");
          let monthName = dateObj.toLocaleString('default', { month: 'long', year: 'numeric' });
          select.innerHTML += `<option value='${sanitizeHTML(m)}'>${sanitizeHTML(monthName)}</option>`;
      });
      
      renderAttendanceTable(months[0]);
  }

  function renderAttendanceTable(selectedMonth = null) {
      if(!selectedMonth) selectedMonth = sanitizeHTML(document.getElementById('attMonthFilter').value);
      let tbody = document.getElementById('modalAttTableBody');
      let summaryBox = document.getElementById('modalAttSummary');
      let yearlySummaryBox = document.getElementById('modalYearlySummary');
      
      // 🚀 Bangladesh Time Logic for Current Real Year
      const bdTime = new Date().toLocaleString("en-US", {timeZone: "Asia/Dhaka"});
      const bdDate = new Date(bdTime);
      const currentBdYear = bdDate.getFullYear();
      const currentBdMonth = bdDate.getMonth() + 1; // 1-12
      
      let dateParts = selectedMonth ? selectedMonth.split('-') : [currentBdYear.toString(), "01"];
      let selectedYear = parseInt(dateParts[0]);
      let selectedMonthNum = parseInt(dateParts[1]);
      
      let isYearFinished = (selectedYear < currentBdYear);

      // 🚀 ১. Yearly Calculation (Hidden until year finishes)
      if (!isYearFinished) {
          yearlySummaryBox.style.display = 'none';
          yearlySummaryBox.innerHTML = '';
      } else {
          let yearlyPresentCount = 0;
          let yearlyAbsentCount = 0;

          if(allAttendanceData) {
              for(let m = 1; m <= 12; m++) {
                  let mStr = selectedYear + "-" + String(m).padStart(2, '0');
                  let mPresent = 0;
                  if(allAttendanceData[mStr]) {
                      mPresent = Object.keys(allAttendanceData[mStr].dates).length;
                  }
                  yearlyPresentCount += mPresent;

                  let daysInM = new Date(selectedYear, m, 0).getDate();
                  let workingDaysInM = Math.max(mPresent, daysInM - 4);
                  yearlyAbsentCount += (workingDaysInM - mPresent);
              }
          }

          yearlySummaryBox.style.display = 'block';
          yearlySummaryBox.innerHTML = `Yearly Total (<span style="color:var(--accent);">${selectedYear}</span>): <span style="font-size: 18px;">${yearlyPresentCount} Days Present</span> <span style="opacity:0.5; margin:0 10px;">|</span> <span style="color:#fecdd3; font-size:18px;">~${yearlyAbsentCount} Days Absent</span>`;
      }

      if(!selectedMonth || !allAttendanceData[selectedMonth]) {
          tbody.innerHTML = '<tr><td colspan="3" style="text-align:center; padding:20px; color:#64748b; font-weight:600;">No attendance records available for this month.</td></tr>';
          summaryBox.style.display = 'none';
          return;
      }
      
      let monthData = allAttendanceData[selectedMonth].dates;
      let dates = Object.keys(monthData).sort().reverse();
      let presentCount = dates.length;
      
      tbody.innerHTML = "";
      dates.forEach(d => {
          let record = monthData[d];
          tbody.innerHTML += `
              <tr style="border-bottom: 1px solid #f1f5f9; transition: 0.2s;">
                  <td style="padding: 12px 15px; font-weight:700; color:var(--text-main); font-size:14px;">${sanitizeHTML(d)}</td>
                  <td style="padding: 12px 15px; color:#059669; font-weight:700; font-size:13px;">${record.in}</td>
                  <td style="padding: 12px 15px; color:#e11d48; font-weight:700; font-size:13px;">${record.out}</td>
              </tr>
          `;
      });
      
      // 🚀 ৩. Month End Logic for Monthly Totals
      let isMonthFinished = false;
      if (selectedYear < currentBdYear) {
          isMonthFinished = true;
      } else if (selectedYear === currentBdYear && selectedMonthNum < currentBdMonth) {
          isMonthFinished = true;
      }
      
      if (!isMonthFinished) {
          // মাস শেষ হয়নি, তাই হিসাব হাইড থাকবে
          summaryBox.style.display = 'none';
          summaryBox.innerHTML = '';
      } else {
          // মাস শেষ হয়েছে, হিসাব দেখাবে
          summaryBox.style.display = 'flex';
          let daysInMonth = new Date(selectedYear, selectedMonthNum, 0).getDate();
          let workingDays = Math.max(presentCount, daysInMonth - 4); 
          let absentCount = workingDays - presentCount;
          
          summaryBox.innerHTML = `
              <span style="display:flex; flex-direction:column; align-items:center;">
                  <small style="color:#64748b; font-size:11px; text-transform:uppercase;">Total Present</small>
                  <span style="font-size:20px;">${presentCount} Days</span>
              </span>
              <span style="display:flex; flex-direction:column; align-items:center;">
                  <small style="color:#64748b; font-size:11px; text-transform:uppercase;">Total Absent</small>
                  <span style="font-size:20px; color:var(--danger);">~${absentCount} Days</span>
              </span>
          `;
      }
  }

