              subHtml += `<div class="dt-row">
                            <div class="dt-row-top">
                                <div class="sub-name" style="color:#f8fafc;">${subName}</div>
                            </div>
                            <div class="dt-row-bottom">
                                <div class="mark-group"><div class="mark-label">${testLabel}</div><div class="mark-val" style="color:#94a3b8;">${sanitizeHTML(d[i]||'0')}</div></div>
                                <div class="mark-group"><div class="mark-label">${mainLabel}</div><div class="mark-val" style="color:#38bdf8;">${sanitizeHTML(d[i+1]||'0')}</div></div>
                            </div>
                          </div>`;
              i += 2;
            }
          }

          markSheetHTML = `
            <div class="digital-transcript">
                <div class="scroll-indicator">⬇️ Scroll down for full details ⬇️</div>
