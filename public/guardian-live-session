                                            <div style="font-weight:700; color:#1e293b; font-size:14px;">${title}</div>
                                            <div style="font-size:11px; color:#64748b; margin-top:3px;">📅 ${date}</div>
                                          </div>
                                          <a href="${sanitizeHTML(link)}" target="_blank" style="background:var(--accent); color:white; padding:8px 16px; border-radius:8px; font-size:12px; font-weight:700; transition:0.3s; white-space:nowrap; text-decoration:none;">VIEW</a>
                                        </div>`;
                  }
              });
          }
          if(count === 0) box.innerHTML = "<div style='padding:15px; color:var(--text-muted); text-align:center; font-weight:500;'>No class materials available.</div>";
      } catch(e) { 
          box.innerHTML = "<div style='padding:15px; color:var(--danger); text-align:center; font-weight:600;'>Materials sync error.</div>"; 
      }
  }

  // Result Renderer Logic
  function renderResults(h, d) {
