                    <h2 style="margin:0; color:#38bdf8; font-size:20px; font-weight:800; letter-spacing:1px;">YOUR CHILD'S MARKSHEET</h2>
                    <p style="margin:5px 0; color:#94a3b8; font-size:12px;">Real-time Secure Academic Record</p>
                </div>
                <div style="padding:15px 20px; background:rgba(0,0,0,0.2); border-radius:16px; margin-bottom:25px; display:flex; justify-content:space-between; font-size:14px; border:1px solid #334155;">
                    <span><span style="color:#94a3b8;">Student ID:</span> <b style="color:#fff;">${std.id}</b></span>
                    <span><span style="color:#94a3b8;">Class:</span> <b style="color:#fff;">${std.class}</b></span>
                </div>
                <div style="margin-bottom:25px;">${subHtml}</div>
                <div class="dt-summary-box">
                    <div style="text-align:center;"><p style="margin:0 0 5px 0; font-size:11px; color:#cbd5e1; font-weight:600;">TOTAL GPA</p><h2 style="margin:0; font-size:32px; color:#fff;">${gpa}</h2></div>
                    <div style="text-align:center;"><p style="margin:0 0 5px 0; font-size:11px; color:#cbd5e1; font-weight:600;">GRADE</p><h2 style="margin:0; font-size:32px; color:#fff;">${grade}</h2></div>
                    <div style="text-align:center;"><p style="margin:0 0 5px 0; font-size:11px; color:#cbd5e1; font-weight:600;">RANK</p><h2 style="margin:0; font-size:32px; color:#fff;">#${pos}</h2></div>
