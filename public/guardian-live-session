            fetch(`${FIREBASE_DB_BASE}/ClassHeaders/${hDocName}`, { headers }).then(r=>r.json()).then(data=>{
                if(data.fields && data.fields.headers) {
                    let headers = JSON.parse(data.fields.headers.stringValue);
                    renderResults(headers, std.resultMarks);
                }
            }).catch(e=>{});
        }

        fetchMat(headers);
        checkGuardianMeetStatus(headers);
    } catch(err) {
        console.log("Token Sync Error");
    }
