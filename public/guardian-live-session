    try {
        const response = await fetch(`${FIREBASE_DB_BASE}/LiveSessions/Guardian`, { headers });
        if(response.ok) {
            const data = await response.json();
            if(data.fields && data.fields.status && data.fields.status.stringValue === "TRUE") {
                const btn = document.getElementById('guardianLiveBtn');
                btn.classList.add('live-active-btn');
                btn.innerHTML = "<span style='font-size:24px;'>🔴</span><span style='color:white;'>LIVE MEETING</span>";
            }
        }
    } catch (e) {}
  }

  async function openGuardianMeetModal() {
    document.getElementById('liveClassModal').style.display = 'flex';
    const body = document.getElementById('liveClassModalBody');
    body.innerHTML = `<div style="text-align:center; font-weight:bold; color:var(--primary);">⏳ Synchronizing...</div>`;
    
    try {
        const token = await auth.currentUser.getIdToken();
        const response = await fetch(`${FIREBASE_DB_BASE}/LiveSessions/Guardian`, { headers: { "Authorization": "Bearer " + token } });
        if(response.ok) {
            const data = await response.json();
            if(data.fields && data.fields.status && data.fields.status.stringValue === "TRUE") {
