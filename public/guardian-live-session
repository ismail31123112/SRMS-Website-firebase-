  // 🚀 Updated Login Flow (Firebase Auth Token First)
  async function handleLogin() {
    const id = sanitizeHTML(document.getElementById('stuID').value.trim());
    let pass = document.getElementById('stuPass').value.trim();
    const btn = document.getElementById('lBtn');
    
    if(!id || !pass) { document.getElementById('err').innerText = "All fields are required."; return; }
    
    if (pass.length > 0 && pass.length < 6) {
        pass = pass.padEnd(6, '0');
    }

    btn.innerHTML = "<span class='loader-spinner' style='border-top-color:#fff;'></span> Authenticating..."; btn.disabled = true;
    try {
        const email = `${id}@srms.edu.bd`;
        
        await auth.signInWithEmailAndPassword(email, pass);
        const token = await auth.currentUser.getIdToken();

        const queryUrl = `${FIREBASE_DB_BASE}:runQuery`;
        const reqBody = {
            structuredQuery: {
                from: [{ collectionId: "Students" }],
                where: { fieldFilter: { field: { fieldPath: "studentID" }, op: "EQUAL", value: { stringValue: id } } },
                limit: 1
            }
        };

        const res = await fetch(queryUrl, { 
            method: "POST", 
            headers: { "Content-Type": "application/json", "Authorization": "Bearer " + token }, 
            body: JSON.stringify(reqBody) 
        });
        const data = await res.json();
        
        if (data && data[0] && data[0].document) {
            const doc = data[0].document;
            const studentFields = doc.fields;
            const stdDocId = doc.name.split('/').pop();

            std = { 
                id: sanitizeHTML(studentFields.studentID?.stringValue || ""),
                name: sanitizeHTML(studentFields.name?.stringValue || "Student"),
                class: sanitizeHTML(studentFields.class?.stringValue || ""),
                roll: sanitizeHTML(studentFields.roll?.stringValue || ""),
                group: sanitizeHTML(studentFields.group?.stringValue || ""),
                phone: sanitizeHTML(studentFields.phone?.stringValue || ""),
                email: sanitizeHTML(studentFields.email?.stringValue || ""),
                schoolFeeDue: sanitizeHTML(studentFields.schoolFeeDue?.stringValue || "0"),
                schoolFeeStatus: sanitizeHTML(studentFields.schoolFeeStatus?.stringValue || ""),
                hostelFeeDue: sanitizeHTML(studentFields.hostelFeeDue?.stringValue || "0"),
                hostelFeeStatus: sanitizeHTML(studentFields.hostelFeeStatus?.stringValue || ""),
                customFees: studentFields.customFees ? JSON.parse(studentFields.customFees.stringValue) : [],
                resultMarks: studentFields.resultMarks ? JSON.parse(studentFields.resultMarks.stringValue) : null
            };
            
            sessionStorage.setItem('srms_guardian_session', JSON.stringify({ std: std }));
            sessionStorage.setItem('srms_student_docId', stdDocId);
            
            document.getElementById('stuPass').value = '';
            showDashboardUI();
            initDash();
        } else { 
            document.getElementById('err').innerText = "Student data not found in database!"; 
