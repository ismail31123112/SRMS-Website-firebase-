          while (i < idx) {
            let hNameTest = h[i] ? h[i].toString() : "Test";
            let hNameMain = h[i+1] ? h[i+1].toString() : "Main";
            let isOpt = hNameTest.toLowerCase().includes("opt") && hNameTest.toLowerCase().includes("name");

            if (isOpt) {
              let optSubName = sanitizeHTML(d[i] || "Optional Subject");
