                let p = attMap[m] || 0; t += p; 
                h += `<tr><td style='border-bottom:1px solid #f1f5f9;padding:12px;font-weight:600;'>${m.substring(0,3)}</td><td style='border-bottom:1px solid #f1f5f9;padding:12px;text-align:right;color:var(--primary);font-weight:800;'>${p} Days</td></tr>`; 
