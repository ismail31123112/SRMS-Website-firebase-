<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Guardian Premium Portal - SRMS</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  /* === Global Premium Styles (Royal Blue Theme) === */
  :root {
    --primary: #1e3a8a; /* Royal Blue */
    --primary-dark: #172554; /* Deep Navy */
    --accent: #ea580c; /* Orange Accent */
    --danger: #e11d48;
    --danger-dark: #be123c;
    --bg-color: #f0f4f8; /* Soft Blue-Gray Background */
    --card-bg: #ffffff;
    --text-main: #1e293b;
    --text-muted: #64748b;
  }
  body { margin: 0; padding: 0; font-family: 'Poppins', sans-serif; background-color: var(--bg-color); color: var(--text-main); overflow-x: hidden; }
  a { text-decoration: none; color: inherit; transition: 0.3s; }
  ul { list-style: none; margin: 0; padding: 0; }
  
  /* Animations */
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes pulseLoader { 0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(30, 58, 138, 0.7); } 70% { transform: scale(1.05); box-shadow: 0 0 0 20px rgba(30, 58, 138, 0); } 100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(30, 58, 138, 0); } }
  @keyframes bounce { 0%, 20%, 50%, 80%, 100% { transform: translateY(0); } 40% { transform: translateY(-8px); } 60% { transform: translateY(-4px); } }
  @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
  .animate-up { animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; }
  .delay-1 { animation-delay: 0.1s; } .delay-2 { animation-delay: 0.2s; } .delay-3 { animation-delay: 0.3s; }

  /* Custom Scrollbar */
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 10px; }
  ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
  ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

  /* === Premium Navbar === */
  #main-navbar { display: none; }
  .navbar { background: var(--card-bg); box-shadow: 0 10px 30px rgba(0,0,0,0.04); position: sticky; top: 0; z-index: 1000; border-bottom: 3px solid var(--accent); }
  .nav-top-container { height: 75px; display: flex; align-items: center; justify-content: space-between; padding: 0 5%; box-sizing: border-box; max-width: 1400px; margin: 0 auto; }
  .nav-brand { font-weight: 800; color: var(--primary); font-size: 18px; letter-spacing: 0.5px; text-transform: uppercase; }
  .nav-link { font-weight: 600; font-size: 13px; color: var(--danger); background: #fff1f2; padding: 10px 20px; border-radius: 8px; text-transform: uppercase; cursor: pointer; transition: 0.3s; }
  .nav-link:hover { color: #fff; background: var(--danger); }

  /* === Premium Banner === */
  #main-banner { display: none; }
  .custom-banner { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: white; padding: 40px 5%; display: flex; align-items: center; justify-content: center; gap: 25px; text-align: left; position: relative; overflow: hidden; }
  .custom-banner::before { content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 60%); z-index: 0; }
  .banner-logo { width: 90px; height: 90px; background: #fff; border-radius: 50%; padding: 8px; border: 3px solid rgba(255,255,255,0.2); object-fit: contain; box-shadow: 0 10px 25px rgba(0,0,0,0.2); z-index: 1; }
  .banner-text { z-index: 1; }
  .banner-text h1 { margin: 0; font-size: 26px; font-weight: 800; text-transform: uppercase; letter-spacing: -0.5px; }
  .school-codes { background: rgba(255, 255, 255, 0.1); display: inline-block; padding: 6px 15px; border-radius: 20px; margin-top: 10px; font-size: 13px; font-weight: 500; color: #e2e8f0; border: 1px solid rgba(255, 255, 255, 0.15); backdrop-filter: blur(5px); }

  /* === Login Section === */
  #login-container { display: flex; justify-content: center; align-items: center; min-height: 100vh; padding: 20px; position: relative; }
  .login-card { background: var(--card-bg); padding: 50px 40px; border-radius: 24px; box-shadow: 0 25px 50px -12px rgba(30, 58, 138, 0.15); width: 100%; max-width: 420px; text-align: center; border-top: 6px solid var(--primary); }
  .login-logo { width: 85px; margin-bottom: 20px; }
  .login-title { color: var(--primary); font-size: 24px; font-weight: 800; text-transform: uppercase; margin-bottom: 5px; }
  .login-subtitle { color: var(--text-muted); font-size: 14px; margin-bottom: 30px; font-weight: 500; }
  input { width: 100%; padding: 15px 18px; margin: 10px 0; border: 2px solid #e2e8f0; border-radius: 12px; font-family: inherit; font-size: 15px; box-sizing: border-box; background: #f8fafc; color: var(--text-main); font-weight: 500; }
  input:focus { border-color: var(--primary); outline: none; background: #fff; box-shadow: 0 0 0 4px rgba(30, 58, 138, 0.1); }
  .login-btn { width: 100%; padding: 16px; background: var(--primary); color: white; border: none; border-radius: 12px; cursor: pointer; font-weight: 700; font-size: 16px; margin-top: 15px; transition: 0.3s; letter-spacing: 0.5px; }
  .login-btn:hover { background: var(--primary-dark); transform: translateY(-3px); box-shadow: 0 15px 25px -5px rgba(30, 58, 138, 0.3); }
  .login-btn:disabled { background: #94a3b8; cursor: not-allowed; transform: none; box-shadow: none; }
  
  /* Forgot Password Link */
  .forgot-pass-btn { display: inline-block; margin-top: 20px; color: var(--accent); font-weight: 600; font-size: 14px; cursor: pointer; transition: 0.3s; border-bottom: 2px solid transparent; }
  .forgot-pass-btn:hover { border-color: var(--accent); color: var(--primary); }

  /* === Premium Loader === */
  #loader { display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(255,255,255,0.95); z-index: 10000; justify-content:center; align-items:center; flex-direction:column; backdrop-filter: blur(10px); }
  .loader-img { width: 80px; height: 80px; animation: pulseLoader 2s infinite; border: 3px solid var(--primary); padding: 5px; border-radius: 50%; background: #fff; margin-bottom: 20px; }
  .loader-text { font-size: 15px; font-weight: 800; color: var(--primary); letter-spacing: 1.5px; text-transform: uppercase; }
  .loader-spinner { border: 3px solid rgba(255,255,255,0.3); border-top: 3px solid var(--primary); border-radius: 50%; width: 18px; height: 18px; animation: spin 1s linear infinite; display: inline-block; vertical-align: middle; margin-right: 8px; }

  /* === Dashboard Layout === */
  #dashboard-section { display: none; padding: 30px 5%; max-width: 1200px; margin: 0 auto; }
  
  /* 🚀 Scroll Cue Wrapper & Animation - VISIBLE EVERYWHERE */
  .scroll-cue-container { width: 100%; margin-bottom: 25px; text-align: center; }
  .scroll-cue { display: inline-block; color: var(--primary); font-size: 14px; font-weight: 700; padding: 10px 25px; background: #e0e7ff; border-radius: 20px; border: 1px solid #c7d2fe; animation: bounce 2s infinite; box-shadow: 0 5px 15px rgba(30, 58, 138, 0.1); }

  .header-card { background: var(--card-bg); padding: 25px 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.03); border-left: 6px solid var(--primary); margin-bottom: 30px; }
  #noticeBox { background: #fff1f2; color: var(--danger-dark); padding: 20px 25px; border-radius: 16px; border-left: 6px solid var(--danger); margin-bottom: 30px; display: none; box-shadow: 0 10px 25px rgba(225, 29, 72, 0.08); }
  
  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px; margin-bottom: 30px; }
  .card { background: var(--card-bg); padding: 30px; border-radius: 24px; box-shadow: 0 15px 35px rgba(0,0,0,0.04); border: 1px solid rgba(0,0,0,0.02); }
  .res-preview { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: white; padding: 40px 30px; border-radius: 24px; text-align: center; position: relative; overflow: hidden; box-shadow: 0 20px 40px rgba(30, 58, 138, 0.2); align-self: start; }
  .res-preview::after { content: 'ACADEMIC RECORD'; position: absolute; top: 15px; right: -40px; transform: rotate(45deg); background: rgba(255,255,255,0.15); padding: 5px 40px; font-size: 10px; font-weight: 800; letter-spacing: 1px; }

  /* === Resource & Link Section === */
  .resource-section { background: var(--card-bg); padding: 35px; border-radius: 24px; box-shadow: 0 15px 35px rgba(0,0,0,0.04); margin-bottom: 40px; }
  .link-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 15px; margin-top: 25px; }
  .l-btn { background: #f8fafc; border: 1px solid #e2e8f0; padding: 20px 10px; border-radius: 16px; text-align: center; transition: all 0.3s ease; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 12px; }
  .l-btn span:first-child { font-size: 26px; }
  .l-btn span:last-child { font-size: 12px; font-weight: 700; color: var(--text-main); text-transform: uppercase; letter-spacing: 0.5px; }
  .l-btn:hover { background: var(--primary); border-color: var(--primary); transform: translateY(-5px); box-shadow: 0 15px 25px rgba(30, 58, 138, 0.15); }
  .l-btn:hover span:last-child { color: white; }

  .live-active-btn { animation: livePulseBtn 2s infinite !important; background: var(--danger) !important; color: white !important; border-color: var(--danger-dark) !important; }
  @keyframes livePulseBtn { 0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(225, 29, 72, 0.4); } 50% { transform: scale(1.03); box-shadow: 0 0 0 15px rgba(225, 29, 72, 0); } 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(225, 29, 72, 0); } }

  /* === Modals === */
  .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.85); z-index: 2000; justify-content: center; align-items: center; backdrop-filter: blur(8px); padding: 20px; box-sizing: border-box; }
  .modal-content { background: var(--card-bg); width: 100%; max-width: 480px; border-radius: 28px; padding: 40px; position: relative; animation: fadeInUp 0.4s ease; overflow-y: auto; max-height: 85vh; box-shadow: 0 25px 50px rgba(0,0,0,0.2); }
  .close-btn { position: absolute; top: 20px; right: 25px; font-size: 32px; cursor: pointer; color: #94a3b8; line-height: 1; transition: 0.3s; }
  .close-btn:hover { color: var(--danger); transform: rotate(90deg); }

  /* === Anti-Forgery Marksheet === */
  .digital-transcript { background: #0f172a; color: #f8fafc; border-radius: 24px; padding: 35px 30px; position: relative; }
  .scroll-indicator { text-align: center; color: #cbd5e1; font-size: 12px; font-weight: 600; margin-bottom: 20px; animation: bounce 2s infinite; background: rgba(255,255,255,0.05); padding: 8px; border-radius: 20px; display: inline-block; width: 100%; box-sizing: border-box; }
  .dt-header { border-bottom: 1px solid #334155; padding-bottom: 20px; margin-bottom: 25px; text-align: center; }
  .dt-row { background: #1e293b; border-radius: 16px; padding: 20px; margin-bottom: 12px; display: flex; flex-direction: column; gap: 10px; border: 1px solid #334155; transition: 0.3s; }
  .dt-row:hover { background: #2dd4bf; border-color: #2dd4bf; }
  .dt-row:hover .sub-name, .dt-row:hover .mark-label, .dt-row:hover .mark-val { color: #0f172a !important; }
  .dt-row-top { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px dashed rgba(255,255,255,0.1); padding-bottom: 10px; }
  .dt-row-bottom { display: flex; justify-content: space-between; align-items: center; }
  .sub-name { font-weight: 700; font-size: 16px; color: #38bdf8; }
  .mark-group { text-align: right; }
  .mark-label { font-size: 11px; color: #94a3b8; text-transform: uppercase; font-weight: 600; }
  .mark-val { font-size: 18px; font-weight: 800; color: #f8fafc; }
  .dt-summary-box { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); padding: 25px; border-radius: 20px; margin-top: 30px; display: flex; justify-content: space-around; align-items: center; box-shadow: 0 10px 30px rgba(0,0,0,0.3); }
  .dt-warning-text { font-size: 10px; color: #64748b; text-align: center; margin-top: 25px; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; }

  @media (max-width: 768px) {
    .custom-banner { flex-direction: column; text-align: center; }
    .grid { grid-template-columns: 1fr; }
    .link-grid { grid-template-columns: repeat(2, 1fr); }
    .dt-row-top, .dt-row-bottom { flex-direction: column; align-items: flex-start; gap: 8px; }
    .mark-group { text-align: left; display: flex; align-items: center; gap: 10px; width: 100%; justify-content: space-between; background: rgba(0,0,0,0.2); padding: 8px 15px; border-radius: 10px; box-sizing: border-box; }
  }
</style>
</head>
<body>

<div id="loader">
    <img src="https://i.postimg.cc/hGQQqrsb/20260117_231551.png" class="loader-img" alt="Loading">
    <div class="loader-text">AUTHENTICATING... PLEASE WAIT</div>
</div>

<div id="login-container" class="animate-up">
    <div class="login-card">
        <img src="https://i.postimg.cc/hGQQqrsb/20260117_231551.png" alt="Logo" class="login-logo">
        <h2 class="login-title">Guardian Portal</h2>
        <div class="login-subtitle">Secured Access for SRMS Parents</div>
        <input type="text" id="stuID" placeholder="Your Child's Student ID" autocomplete="off">
        <input type="password" id="stuPass" placeholder="Password">
        <button id="lBtn" class="login-btn" onclick="handleLogin()">ENTER PORTAL</button>
        <div class="forgot-pass-btn" onclick="openForgotPassModal()">Forgot Password?</div>
        <p id="err" style="color:var(--danger); font-size:13px; margin-top:15px; font-weight:700;"></p>
    </div>
</div>

<nav class="navbar" id="main-navbar">
  <div class="nav-top-container">
    <div class="nav-brand">SRMS Guardian Portal</div>
    <a class="nav-link" onclick="logout()">LOGOUT 🔒</a>
  </div>
</nav>

<div class="custom-banner" id="main-banner">
  <img src="https://i.postimg.cc/hGQQqrsb/20260117_231551.png" class="banner-logo" alt="Logo">
  <div class="banner-text">
    <h1>Guardian Dashboard</h1>
    <div class="school-codes">Access your child's educational records securely</div>
  </div>
</div>

<div id="dashboard-section">
    <div class="scroll-cue-container animate-up delay-1">
        <div class="scroll-cue">⬇️ Scroll down for more options ⬇️</div>
    </div>

    <div class="header-card animate-up delay-1">
        <div>
            <h3 id="uName" style="margin:0; color:var(--primary); font-size:24px; font-weight:800;">Assalamu Alaikum...</h3>
            <p id="uMeta" style="margin:5px 0 0 0; font-size:14px; color:var(--text-muted); font-weight:600;"></p>
        </div>
    </div>

    <div id="noticeBox" class="animate-up delay-1">
        <h4 style="margin:0; font-size:16px; display:flex; align-items:center; gap:8px;"><span>⚠️</span> IMPORTANT NOTICE FOR YOUR CHILD</h4>
        <p id="noticeText" style="margin:8px 0 0 0; font-size:14.5px; font-weight:600; line-height:1.5;"></p>
    </div>

    <div class="card animate-up delay-2" style="border-left: 6px solid var(--accent); margin-bottom: 30px;">
        <h3 style="margin:0 0 15px 0; color:var(--primary); font-size:18px;">📚 Class Materials & Content</h3>
        <div id="matList" style="font-size:14.5px; color:#475569; max-height: 350px; overflow-y: auto; padding-right: 5px;"></div>
    </div>

    <div class="grid">
        <div class="res-preview animate-up delay-2">
            <p style="margin:0; font-size:12px; font-weight:700; opacity:0.8; letter-spacing:1px;">YOUR CHILD'S PERFORMANCE</p>
            <h1 id="appGPA" style="margin:15px 0; font-size:52px; font-weight:900;">GPA: --</h1>
            <p id="appMeta" style="margin:0; font-size:16px; font-weight:600; background:rgba(255,255,255,0.1); display:inline-block; padding:8px 20px; border-radius:12px;">Grade: -- | Rank: --</p>
            <div id="appSession" style="font-size:13px; font-weight:600; margin-top:20px; opacity:0.9;">Session: --</div>
            <button class="login-btn" style="background:var(--accent); color:white; margin-top:25px; font-size:15px; border-radius:16px;" onclick="viewResultModal()">VIEW FULL MARKSHEET</button>
        </div>

        <div class="card animate-up delay-3" style="padding:25px;">
            <h3 style="margin:0 0 20px 0; color:var(--text-main); font-size:18px;">📅 Your Child's Attendance</h3>
            <table id="attTable" style="width:100%; border-collapse: collapse; font-size: 14px;"></table>
            <div id="attSummary" style="margin-top:15px; font-weight:800; color:var(--primary); padding:12px; background:var(--bg-color); border-radius:12px; text-align:center;"></div>
            
            <button class="login-btn" style="background:var(--primary); color:white; margin-top:20px; font-size:14px; border-radius:12px; padding: 12px;" onclick="openAttendanceModal()">VIEW DETAILED LOGS</button>
        </div>
    </div>

    <div class="resource-section animate-up delay-3">
        <h3 style="margin:0; color:var(--text-main); font-size:22px; border-bottom:2px solid #f1f5f9; padding-bottom:15px;">📚 Dashboard Quick Links</h3>
        <div class="link-grid">
            <a onclick="openFeesModal();" class="l-btn"><span>💳</span><span>Pay Fees</span></a>
            <a id="guardianLiveBtn" onclick="openGuardianMeetModal();" class="l-btn" style="border: 2px solid var(--primary);"><span>🎥</span><span>Guardian Meet</span></a>
            <a href="https://www.saidpurresidentialmodelschool.com/menu/academic/syllabus" target="_blank" class="l-btn"><span>📖</span><span>Syllabus</span></a>
            <a href="https://www.saidpurresidentialmodelschool.com/menu/academic/class-routine" target="_blank" class="l-btn"><span>🎯</span><span>Routine</span></a>
            <a href="https://www.saidpurresidentialmodelschool.com/menu/academic/exam-routine" target="_blank" class="l-btn"><span>📅</span><span>Exams</span></a>
            <a href="https://www.saidpurresidentialmodelschool.com/notice-board" target="_blank" class="l-btn"><span>📢</span><span>Notice</span></a>
            <a href="https://www.saidpurresidentialmodelschool.com/menu/gallery" target="_blank" class="l-btn"><span>🖼️</span><span>Gallery</span></a>
            <a onclick="openSecurityModal();" class="l-btn"><span>🔐</span><span>Security</span></a>
            <a href="https://www.saidpurresidentialmodelschool.com/menu/contact-us" target="_blank" class="l-btn"><span>📞</span><span>Support</span></a>
        </div>
    </div>
</div>

<div id="forgotPassModal" class="modal-overlay">
    <div class="modal-content" style="text-align: center;">
        <span class="close-btn" onclick="closeModal('forgotPassModal')">×</span>
        <h3 style="color:var(--primary); margin:0 0 5px 0; font-size:22px;">Reset Password</h3>
        <p style="color:var(--text-muted); font-size:13px; margin-bottom:20px;">Verify email to reset child's account security key</p>
        
        <div id="fpStep1">
            <input type="text" id="fpID" placeholder="Enter your Child's Student ID">
            <button id="btnRequestOTP" class="login-btn" onclick="requestOTP()">SEND OTP TO EMAIL</button>
        </div>
        
        <div id="fpStep2" style="display:none;">
            <input type="text" id="fpOTP" placeholder="Enter 6-digit OTP">
            <button id="btnVerifyOTP" class="login-btn" onclick="verifyOTP()">VERIFY OTP</button>
        </div>
        
        <div id="fpStep3" style="display:none;">
            <input type="password" id="fpNewPass" placeholder="Enter New Password (Min. 6 chars)">
            <button id="btnSaveReset" class="login-btn" onclick="saveResetPassword()">SAVE NEW PASSWORD</button>
        </div>
        
        <p id="fpMsg" style="font-size:13px; font-weight:700; margin-top:15px;"></p>
    </div>
</div>

<div id="feesModal" class="modal-overlay">
    <div class="modal-content">
        <span class="close-btn" onclick="closeModal('feesModal')">×</span>
        <div id="feesModalBody"></div>
    </div>
</div>

<div id="liveClassModal" class="modal-overlay">
    <div class="modal-content">
        <span class="close-btn" onclick="closeModal('liveClassModal')">×</span>
        <div id="liveClassModalBody"></div>
    </div>
</div>

<div id="resultModal" class="modal-overlay">
    <div class="modal-content" style="max-width:700px; background: #0f172a; padding: 0;">
        <span class="close-btn" onclick="closeModal('resultModal')" style="color:#fff; top:15px; right:20px; z-index:100;">×</span>
        <div id="resultModalBody" style="padding:0;"></div>
    </div>
</div>

<div id="attendanceModal" class="modal-overlay">
    <div class="modal-content" style="max-width: 600px;">
        <span class="close-btn" onclick="closeModal('attendanceModal')">×</span>
        <h3 style="margin:0 0 20px 0; color:var(--text-main); font-size:20px; border-bottom:2px solid #f1f5f9; padding-bottom:15px;">📅 Detailed Attendance Logs</h3>
        
        <div style="margin-bottom: 15px;">
            <select id="attMonthFilter" onchange="renderAttendanceTable()" style="width:100%; padding: 12px; border-radius: 8px; border: 2px solid #e2e8f0; outline:none; font-family:inherit; font-weight:600; color:var(--text-main); cursor:pointer;">
                <option value=''>Loading Months...</option>
            </select>
        </div>
        
        <div id="attLoader" style="text-align:center; color:var(--primary); font-weight:bold; display:none; padding:20px 0;">
            <span class="loader-spinner"></span> Synchronizing Data...
        </div>
        
        <div id="modalYearlySummary" style="margin-bottom:15px; font-weight:700; color:#fff; padding:15px; background:linear-gradient(135deg, var(--primary), var(--primary-dark)); border-radius:12px; text-align:center; box-shadow: 0 5px 15px rgba(30, 58, 138, 0.2); display: none;">
            </div>

        <div style="max-height: 350px; overflow-y: auto; border: 1px solid #e2e8f0; border-radius: 12px; background: #f8fafc;">
            <table style="width:100%; border-collapse: collapse; font-size: 13px; text-align: left;">
                <thead style="background: #e2e8f0; position: sticky; top: 0; z-index: 10;">
                    <tr>
