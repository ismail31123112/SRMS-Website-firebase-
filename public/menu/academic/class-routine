<script>
  function toggleMenu() { document.getElementById('navMenu').classList.toggle('active'); }
  function handleDropdown(el) {
    if (window.innerWidth <= 950) {
      const parent = el.parentElement;
      const isActive = parent.classList.contains('active');
      document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
      if (!isActive) parent.classList.add('active');
    }
  }
  window.addEventListener('click', function(e) {
    if (!e.target.closest('.nav-item')) {
      document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
    }
  });

  const FIREBASE_PROJECT_ID = "srms-website-management";
  const FIREBASE_DB_BASE = `https://firestore.googleapis.com/v1/projects/${FIREBASE_PROJECT_ID}/databases/(default)/documents`;
  const TARGET_PAGE = "Routine";

  async function loadRoutines() {
    const container = document.getElementById('main-container');
    
    try {
      const response = await fetch(`${FIREBASE_DB_BASE}/WebsitePosts?pageSize=1000`);
      const data = await response.json();
      
      let routineItems = [];
      if (data.documents) {
        data.documents.forEach(doc => {
          let f = doc.fields || {};
          if (f.targetPage && f.targetPage.stringValue === TARGET_PAGE) {
            routineItems.push({
              date: f.date ? f.date.stringValue : "",
              title: f.title ? f.title.stringValue : "",
              desc: f.desc ? f.desc.stringValue : "",
              fileType: f.fileType ? f.fileType.stringValue : "None",
              fileUrl: f.fileUrl ? f.fileUrl.stringValue : "",
              timestamp: f.timestamp ? parseInt(f.timestamp.integerValue || f.timestamp.stringValue) : 0
            });
          }
        });
      }

      // Sort by timestamp descending (Newest first)
      routineItems.sort((a, b) => b.timestamp - a.timestamp);

      container.innerHTML = ""; 
      let hasData = false; 
      let delayCount = 0;

      routineItems.forEach(item => {
        hasData = true;
        let fileId = (item.fileUrl.match(/id=([^&]+)/)||item.fileUrl.match(/\/d\/([^\/]+)/)||[])[1];
        let imgHTML = "", btnHTML = ""; 
        let animDelay = delayCount * 0.15; 
        delayCount++;

        if(fileId) {
           if(item.fileType === "Image") {
             let driveImg = `https://drive.google.com/thumbnail?id=${fileId}&sz=w800`;
             imgHTML = `<img src="${driveImg}" class="r-img" onclick="window.open('https://drive.google.com/uc?id=${fileId}')">`;
             btnHTML = `<a href="https://drive.google.com/uc?id=${fileId}" target="_blank" class="btn btn-view">👁️ View Full Routine</a>`;
           } else {
             imgHTML = `<div class="pdf-placeholder" onclick="window.open('${item.fileUrl}')"><span style="font-size:40px;">📄</span><span>PDF Document</span></div>`;
             btnHTML = `<a href="https://drive.google.com/uc?export=download&id=${fileId}" class="btn btn-pdf">⬇ Download PDF</a>`;
           }
        } 

        container.innerHTML += `
          <div class="r-card" style="animation-delay: ${animDelay}s;">
            <div class="r-img-box">${imgHTML}</div>
            <div class="r-info">
              <div>
                <span class="r-title">${item.title}</span><br>
                <span class="r-desc">${item.desc}</span>
              </div>
              ${btnHTML}
            </div>
          </div>`;
      });

      if(!hasData) {
          container.innerHTML = `<div style="text-align:center; grid-column:1/-1; padding:40px; color:#666;">No routine found.</div>`;
      }

    } catch (error) {
      console.error(error);
      container.innerHTML = `<div style="text-align:center; grid-column:1/-1; padding:60px; color: red;">⚠️ Error loading routines. Please check your internet connection.</div>`;
    }
  }

  loadRoutines();
</script>
