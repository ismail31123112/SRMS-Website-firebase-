<script>
  function toggleMenu() { document.getElementById('navMenu').classList.toggle('active'); }
  function handleDropdown(el) { if (window.innerWidth <= 950) { const parent = el.parentElement; const isActive = parent.classList.contains('active'); document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active')); if (!isActive) parent.classList.add('active'); } }
  window.addEventListener('click', function(e) { if (!e.target.closest('.nav-item')) { document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active')); } });

  const FIREBASE_PROJECT_ID = "srms-website-management";
  const FIREBASE_DB_BASE = `https://firestore.googleapis.com/v1/projects/${FIREBASE_PROJECT_ID}/databases/(default)/documents`;
  const TARGET_PAGE = "Syllabus";

  async function loadSyllabus() {
    const container = document.getElementById('main-container');
    
    try {
      const response = await fetch(`${FIREBASE_DB_BASE}/WebsitePosts?pageSize=1000`);
      const data = await response.json();
      
      let syllabusItems = [];
      if (data.documents) {
        data.documents.forEach(doc => {
          let f = doc.fields || {};
          if (f.targetPage && f.targetPage.stringValue === TARGET_PAGE) {
            syllabusItems.push({
              date: f.date ? f.date.stringValue : "",
              title: f.title ? f.title.stringValue : "",
              desc: f.desc ? f.desc.stringValue : "",
              fileUrl: f.fileUrl ? f.fileUrl.stringValue : "",
              timestamp: f.timestamp ? parseInt(f.timestamp.integerValue || f.timestamp.stringValue) : 0
            });
          }
        });
      }

      // Sort by timestamp descending (Newest first)
      syllabusItems.sort((a, b) => b.timestamp - a.timestamp);

      container.innerHTML = ""; 
      let hasData = false; 
      let delayCount = 0; 

      syllabusItems.forEach(item => {
        hasData = true;
        let fileId = (item.fileUrl.match(/id=([^&]+)/)||item.fileUrl.match(/\/d\/([^\/]+)/)||[])[1];
        let animDelay = delayCount * 0.15; 
        delayCount++; 
        
        let btnHTML = fileId ? `<a href="https://drive.google.com/uc?export=download&id=${fileId}" class="btn-pdf"><span>⬇</span> Download PDF</a>` : `<span style="color:#999; font-size:12px;">No File</span>`; 
        
        container.innerHTML += `
            <div class="syllabus-card" style="animation-delay: ${animDelay}s;">
                <div class="card-left">
                    <div class="icon-box">📘</div>
                    <div class="s-info">
                        <span class="s-title">${item.title}</span>
                        <span class="s-desc">${item.desc}</span>
                        <span class="s-date">📅 ${item.date}</span>
                    </div>
                </div>
                ${btnHTML}
            </div>`; 
      });

      if(!hasData) {
          container.innerHTML = `<div style="text-align:center; padding:40px; color:#666;">No syllabus found.</div>`;
      }

    } catch (error) {
      console.error(error);
      container.innerHTML = `<div style="text-align:center; padding:60px; color: red;">⚠️ Error loading syllabus. Please check your internet connection.</div>`;
    }
  }

  loadSyllabus();
</script>
