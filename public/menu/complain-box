<script>
  function toggleMenu() { document.getElementById('navMenu').classList.toggle('active'); }
  function handleDropdown(el) {
    if (window.innerWidth <= 950) {
      const parent = el.parentElement;
      const isActive = parent.classList.contains('active');
      document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
      if (!isActive) parent.classList.add('active');
    }
  }
  window.addEventListener('click', function(e) {
    if (!e.target.closest('.nav-item')) {
      document.querySelectorAll('.nav-item').forEach(item => { item.classList.remove('active'); });
    }
  });

  (function(){
      const form = document.getElementById('comp-form');
      const msg = document.getElementById('comp-success');
      const headerDiv = document.getElementById('form-header-div');
      const btn = document.getElementById('comp-btn');

      form.addEventListener('submit', function(e) {
          e.preventDefault(); 
          btn.innerHTML = "⏳ Sending..."; 
          btn.disabled = true;

          const scriptURL = 'https://script.google.com/macros/s/AKfycbyuDpo-fAqjuGDc3dPSsiK5oln26RYLq_GPumxVpAUg4A8MuHYETbkvWAJEvaR6uINp/exec';

          fetch(scriptURL, { 
              method: "POST", 
              body: new FormData(form) 
          })
          .then(r => {
              alert("অভিযোগটি সফলভাবে পাঠানো হয়েছে।");
              form.style.display="none"; 
              if(headerDiv) headerDiv.style.display="none";
              msg.style.display="block"; 
          })
          .catch(err => {
              alert("দুঃখিত, কোনো সমস্যা হয়েছে। আবার চেষ্টা করুন।");
              btn.innerHTML = "SUBMIT COMPLAINT";
              btn.disabled = false;
          });
      });
  })();
</script>
