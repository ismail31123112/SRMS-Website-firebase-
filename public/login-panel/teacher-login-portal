  async function requestOTP(method) {
    let p = document.getElementById('fpPhone').value.trim();
    if(!p) { document.getElementById('fpMsg').innerHTML = "<span style='color:var(--danger);'>Please enter mobile number.</span>"; return; }
    resetPhone = p.startsWith('0') ? p.substring(1) : p; 
    document.getElementById('fpMsg').innerHTML = "<span class='loader-spinner' style='border-top-color:var(--primary);'></span> Sending Request...";
    
    try {
      const response = await fetch(OTP_SCRIPT_URL, { 
          method: "POST", 
          headers: { "Content-Type": "text/plain;charset=utf-8" },
          body: JSON.stringify({ action: "sendOTP", phone: resetPhone, method: method }) 
      });
      
      const textData = await response.text(); 
      let data;
      try { data = JSON.parse(textData); } catch (parseError) { document.getElementById('fpMsg').innerHTML = `<span style="color:var(--danger);">Server Error! Check Browser Console.</span>`; return; }
      
      if(data.status === "success") {
        document.getElementById('fpStep1').style.display = 'none'; 
        document.getElementById('fpStep2').style.display = 'block';
        let sMsg = data.msg ? data.msg : (data.message ? data.message : "OTP Sent Successfully!");
        document.getElementById('fpMsg').innerHTML = `<span style="color:#059669;">${sanitizeHTML(sMsg)}</span>`;
      } else { 
        let eMsg = data.message ? data.message : (data.msg ? data.msg : "Error sending OTP.");
        document.getElementById('fpMsg').innerHTML = `<span style="color:var(--danger);">${sanitizeHTML(eMsg)}</span>`; 
      }
    } catch(e) { document.getElementById('fpMsg').innerHTML = "<span style='color:var(--danger);'>Network Error! Check connection.</span>"; }
  }

