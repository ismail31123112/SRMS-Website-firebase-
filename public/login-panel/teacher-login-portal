<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Teacher Premium Portal - SRMS</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
  /* === Global Premium Styles === */
  :root {
    --primary: #005f40;
    --primary-dark: #003d29;
    --accent: #bf953f;
    --danger: #e11d48;
    --danger-dark: #be123c;
    --warning: #f59e0b;
    --success: #10b981;
    --bg-color: #f4f7f6;
    --card-bg: #ffffff;
    --text-main: #1e293b;
    --text-muted: #64748b;
  }
  body { margin: 0; padding: 0; font-family: 'Poppins', sans-serif; background-color: var(--bg-color); color: var(--text-main); overflow-x: hidden; }
  a { text-decoration: none; color: inherit; transition: 0.3s; }
  ul { list-style: none; margin: 0; padding: 0; }
  
  /* Animations */
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(25px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes bounce { 0%, 20%, 50%, 80%, 100% { transform: translateY(0); } 40% { transform: translateY(-8px); } 60% { transform: translateY(-4px); } }
  @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
  .animate-up { animation: fadeInUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; }

  /* Custom Scrollbar */
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 10px; }
  ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
  ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

  /* === Premium Navbar === */
  #main-navbar { display: none; background: var(--card-bg); box-shadow: 0 4px 20px rgba(0,0,0,0.06); position: sticky; top: 0; z-index: 1000; border-bottom: 3px solid var(--accent); }
  .nav-top-container { height: 75px; display: flex; align-items: center; justify-content: space-between; padding: 0 5%; max-width: 1400px; margin: 0 auto; box-sizing: border-box; }
  .nav-brand { font-weight: 800; color: var(--primary); font-size: 20px; text-transform: uppercase; letter-spacing: 0.5px; }
  .nav-link { font-weight: 700; font-size: 13px; color: var(--danger); background: #fff1f2; padding: 10px 20px; border-radius: 8px; text-transform: uppercase; cursor: pointer; transition: 0.3s; }
  .nav-link:hover { color: #fff; background: var(--danger); box-shadow: 0 5px 15px rgba(225, 29, 72, 0.3); }

  /* === Premium Banner === */
  #main-banner { display: none; background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: white; padding: 40px 5%; display: flex; align-items: center; justify-content: center; gap: 25px; text-align: left; position: relative; overflow: hidden; }
  .custom-banner::before { content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 60%); z-index: 0; }
  .banner-logo { width: 90px; height: 90px; background: #fff; border-radius: 50%; padding: 8px; border: 3px solid rgba(255,255,255,0.2); object-fit: contain; box-shadow: 0 10px 25px rgba(0,0,0,0.2); z-index: 1; }
  .banner-text { z-index: 1; }
  .banner-text h1 { margin: 0; font-size: 26px; font-weight: 800; text-transform: uppercase; letter-spacing: -0.5px; }
  .school-codes { background: rgba(255, 255, 255, 0.1); display: inline-block; padding: 6px 15px; border-radius: 20px; margin-top: 10px; font-size: 13px; font-weight: 500; color: #fcf6ba; border: 1px solid rgba(255, 255, 255, 0.15); backdrop-filter: blur(5px); }

  /* === Login Section === */
  #login-sec { display: flex; justify-content: center; align-items: center; min-height: 100vh; padding: 20px; position: relative; overflow: hidden; }
  #login-sec::after { content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: radial-gradient(circle at top right, rgba(0,95,64,0.05) 0%, transparent 50%); z-index: -1; }
  .login-card { background: var(--card-bg); padding: 50px 40px; border-radius: 24px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.1); width: 100%; max-width: 450px; text-align: center; border: 1px solid rgba(0,0,0,0.05); box-sizing: border-box; }
  .login-logo { width: 85px; margin-bottom: 20px; }
  .login-title { color: var(--primary); font-size: 24px; font-weight: 800; text-transform: uppercase; margin: 0 0 5px 0; }
  .login-subtitle { color: var(--text-muted); font-size: 14px; margin-bottom: 30px; font-weight: 500; }

  /* === General Form Styles === */
  input, select, textarea { width: 100%; padding: 15px 18px; margin: 10px 0; border: 2px solid #e2e8f0; border-radius: 12px; font-family: inherit; font-size: 15px; transition: 0.3s; box-sizing: border-box; background: #f8fafc; color: var(--text-main); font-weight: 500; }
  input:focus, select:focus, textarea:focus { border-color: var(--primary); outline: none; background: #fff; box-shadow: 0 0 0 4px rgba(0,95,64,0.1); }
  .btn-p { width: 100%; padding: 16px; background: var(--primary); color: white; border: none; border-radius: 12px; cursor: pointer; font-weight: 700; font-size: 15px; margin-top: 15px; transition: all 0.3s ease; text-transform: uppercase; letter-spacing: 0.5px; }
  .btn-p:hover { background: var(--primary-dark); transform: translateY(-3px); box-shadow: 0 15px 25px -5px rgba(0,95,64,0.3); }
  .btn-p:active { transform: translateY(-1px); }
  .btn-p:disabled { background: #94a3b8; cursor: not-allowed; transform: none; box-shadow: none; }
  .btn-success { background: #059669; } .btn-success:hover { background: #047857; }
  
  .forgot-link { display: inline-block; margin-top: 20px; color: var(--accent); font-weight: 600; font-size: 14px; cursor: pointer; transition: 0.3s; border-bottom: 2px solid transparent; }
  .forgot-link:hover { border-color: var(--accent); color: var(--primary); }
  
  .loader-spinner { border: 3px solid rgba(255,255,255,0.3); border-top: 3px solid #fff; border-radius: 50%; width: 18px; height: 18px; animation: spin 1s linear infinite; display: inline-block; vertical-align: middle; margin-right: 8px; }

  /* === Dashboard Section === */
  .container { max-width: 1000px; margin: 0 auto; padding: 40px 5%; display: none; }
  
  /* 🚀 Scroll Cue Animation - TOP POSITION */
  .scroll-cue-container { width: 100%; margin-bottom: 30px; text-align: center; }
  .scroll-cue { display: inline-block; color: var(--danger); font-size: 15px; font-weight: 700; padding: 10px 25px; background: #fff1f2; border-radius: 20px; border: 1px solid #fecdd3; animation: bounce 2s infinite; box-shadow: 0 5px 15px rgba(225, 29, 72, 0.1); }

  .welcome-card { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: white; padding: 35px 30px; border-radius: 20px; margin-bottom: 35px; border-left: 8px solid var(--accent); display: flex; justify-content: space-between; align-items: center; box-shadow: 0 15px 35px rgba(0,95,64,0.2); flex-wrap: wrap; gap: 20px; }
  .welcome-card h2 { margin: 0; font-size: 26px; font-weight: 800; }
  .welcome-card p { margin: 5px 0 0 0; opacity: 0.9; font-weight: 500; }
  .btn-gold { background: var(--accent); padding: 12px 25px; border: none; color: white; border-radius: 12px; cursor: pointer; font-weight: 700; transition: 0.3s; font-size: 15px; box-shadow: 0 5px 15px rgba(191, 149, 63, 0.3); }
  .btn-gold:hover { background: #a67c2e; transform: translateY(-2px); }

  .section-title { font-weight: 800; color: var(--text-main); margin: 40px 0 15px; font-size: 18px; text-transform: uppercase; display: flex; align-items: center; gap: 10px; border-bottom: 2px solid #e2e8f0; padding-bottom: 10px; }
  .card { background: var(--card-bg); border-radius: 20px; padding: 35px; margin-bottom: 30px; box-shadow: 0 15px 35px rgba(0,0,0,0.04); border: 1px solid rgba(0,0,0,0.02); }

  .action-btn-large { width: 100%; padding: 20px; font-size: 16px; border-radius: 16px; display: flex; align-items: center; justify-content: center; gap: 10px; }

  /* Board Items */
  .notice-item { background: #f8fafc; border: 1px solid #e2e8f0; padding: 20px; border-radius: 16px; margin-bottom: 15px; border-left: 6px solid var(--accent); transition: 0.3s; }
  .notice-item:hover { box-shadow: 0 5px 15px rgba(0,0,0,0.05); transform: translateX(5px); }
  .item-box { background: #fff; border: 1px solid #e2e8f0; padding: 25px; border-radius: 16px; margin-bottom: 15px; position: relative; border-left: 6px solid var(--primary); transition: 0.3s; }
  .item-box:hover { box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
  .del-btn { position: absolute; right: 20px; top: 20px; color: var(--danger); cursor: pointer; font-size: 12px; border: 2px solid #fecdd3; padding: 8px 16px; border-radius: 10px; font-weight: 700; background: #fff1f2; transition: 0.3s; }
  .del-btn:hover { background: var(--danger); color: white; border-color: var(--danger); }
  .tag { background: #f1f5f9; color: #475569; padding: 5px 12px; border-radius: 6px; font-size: 12px; font-weight: 700; display: inline-block; margin-bottom: 10px; }

  /* Modals */
  .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.85); z-index: 2000; justify-content: center; align-items: center; backdrop-filter: blur(8px); padding: 20px; box-sizing: border-box; }
  .modal-box { background: var(--card-bg); padding: 40px; border-radius: 28px; text-align: center; width: 100%; max-width: 480px; box-shadow: 0 25px 50px rgba(0,0,0,0.2); animation: fadeInUp 0.4s ease; border-top: 8px solid var(--accent); position: relative; max-height: 90vh; overflow-y: auto;}
  .modal-box.danger-modal { border-top-color: var(--danger); }
  .close-modal-btn { background: #f1f5f9; color: #333; border: none; padding: 14px; border-radius: 12px; cursor: pointer; font-weight: 700; width: 100%; transition: 0.3s; margin-top: 10px; font-size: 15px; }
  .close-modal-btn:hover { background: #e2e8f0; }
  .at-input { width: 90px !important; padding: 10px !important; text-align: center; border: 2px solid var(--primary) !important; font-weight: 800; border-radius: 10px !important; font-size: 16px; }
  .premium-footer { display: none; background: #0f172a; color: #f8fafc; padding: 50px 5% 30px; margin-top: 60px; text-align: center; border-top: 5px solid var(--primary); }

  @media (max-width: 768px) {
    .nav-brand { font-size: 16px; }
    .custom-banner { flex-direction: column; text-align: center; padding: 30px 20px; }
    .banner-text h1 { font-size: 22px; }
    .login-card { padding: 40px 25px; border-radius: 20px; }
    .container { padding: 30px 20px; }
    .welcome-card { flex-direction: column; text-align: center; padding: 30px 20px; }
    .welcome-card h2 { font-size: 22px; }
    .btn-gold { width: 100%; margin-top: 10px; }
    .card { padding: 25px 20px; }
    .del-btn { position: relative; right: auto; top: auto; display: inline-block; margin-top: 15px; width: 100%; text-align: center; box-sizing: border-box; }
  }
</style>
</head>
<body>

<nav class="navbar" id="main-navbar">
  <div class="nav-top-container">
    <div class="nav-brand">SRMS Portal</div>
    <a onclick="logout()" class="nav-link"><i class="fas fa-lock"></i> Logout</a>
  </div>
</nav>

<div class="custom-banner animate-up" id="main-banner">
  <img src="https://i.postimg.cc/hGQQqrsb/20260117_231551.png" class="banner-logo" alt="Logo">
  <div class="banner-text">
    <h1>Saidpur Residential Model School</h1>
    <div class="school-codes">Smart Teacher Dashboard</div>
  </div>
</div>

<div id="login-sec" class="animate-up">
    <div class="login-card">
        <img src="https://i.postimg.cc/hGQQqrsb/20260117_231551.png" alt="Logo" class="login-logo">
        <h2 class="login-title">Teacher Login</h2>
        <div class="login-subtitle">Access your academic dashboard</div>
        <input type="tel" id="lPh" placeholder="Mobile Number (e.g. 017...)">
        <input type="password" id="lPs" placeholder="Password">
        <button class="btn-p" id="lBtn" onclick="login()">Secure Login ➔</button>
        <div class="forgot-link" onclick="openForgotModal()">Forgot Password?</div>
        <p id="err" style="color:var(--danger); font-size:13px; margin-top:15px; font-weight:700;"></p>
    </div>
</div>

<div id="dash-sec" class="container animate-up">
    <div class="scroll-cue-container">
        <div class="scroll-cue">⬇️ Scroll down for more options ⬇️</div>
    </div>

    <div class="welcome-card">
      <div>
        <h2 id="tGreet" style="margin:0;">Assalamu Alaikum</h2>
        <p>Academic Management Portal</p>
      </div>
      <button class="btn-gold" onclick="togglePass()">Change Key 🔑</button>
    </div>

    <div id="passBox" class="card" style="display:none; border-top-color:var(--accent);">
      <h3 style="margin-top:0; color:var(--text-main);">🔐 Update Security Key</h3>
      <input type="password" id="newPass" placeholder="Enter New Password (Min. 6 chars)">
      <button id="passBtn" class="btn-p" style="background:var(--accent);" onclick="changePass()">Save Password</button>
    </div>

    <div class="section-title">🎥 Live Class Hub</div>
    <div class="card" style="padding: 20px;">
        <a href="https://www.saidpurresidentialmodelschool.com/live-classmeeting-panel" target="_blank" style="text-decoration:none;">
            <button class="btn-p action-btn-large"><i class="fas fa-video"></i> Start Live Class / Meeting</button>
        </a>
    </div>

    <div class="section-title">📢 Official Notice Board</div>
    <div class="card" id="notice-board"><p style="text-align:center; color:var(--text-muted); font-weight:600;">⌛ Syncing notices...</p></div>
    
    <div class="section-title">⚠️ Disciplinary Warning System</div>
    <div class="card">
        <select id="wCls" onchange="loadStudentsForWarn()">
            <option value="">Select Class...</option>
            <option value="Play">Play</option><option value="Nursery">Nursery</option><option value="KG">KG</option>
            <option value="1">1</option><option value="2">2</option><option value="3">3</option><option value="4">4</option>
            <option value="5">5</option><option value="6">6</option><option value="7">7</option><option value="8">8</option>
            <option value="9">9</option><option value="10">10</option>
        </select>
        <div id="wStuBox" style="margin-top:10px;"></div>
        <textarea id="wMsg" rows="3" placeholder="Write warning/notice message here..."></textarea>
        <button class="btn-p" style="background:var(--danger);" id="wBtn" onclick="sendWarning()"><i class="fas fa-exclamation-triangle"></i> Send Warning Directly</button>
    </div>

    <div class="section-title">📤 Academic Content Publishing</div>
    <div class="card">
      <select id="uCls">
          <option value="">Select Target Audience...</option>
          <option value="TeacherDashboard">Teacher Dashboard (Internal Notice)</option>
          <option value="ClassPlay">Class Play</option><option value="ClassNursery">Class Nursery</option>
          <option value="ClassKG">Class KG</option><option value="Class1">Class 1</option>
          <option value="Class2">Class 2</option><option value="Class3">Class 3</option>
          <option value="Class4">Class 4</option><option value="Class5">Class 5</option>
          <option value="Class6">Class 6</option><option value="Class7">Class 7</option>
          <option value="Class8">Class 8</option><option value="Class9">Class 9</option>
          <option value="Class10">Class 10</option>
      </select>
      <input type="text" id="uTtl" placeholder="Post Title / Subject Name">
      <textarea id="uDsc" rows="3" placeholder="Description / Instructions"></textarea>
      <input type="url" id="uUrl" placeholder="Enter Document or Drive Link (Optional)">
      <button class="btn-p" id="uBtn" onclick="upload()"><i class="fas fa-cloud-upload-alt"></i> Publish Content</button>
    </div>

    <div class="section-title">📊 My Attendance Record</div>
    <div class="card" style="padding: 30px;">
        <p style="color:var(--text-muted); font-size:15px; font-weight:500; margin-bottom:20px; line-height:1.6;">সম্মানিত শিক্ষক, আপনার প্রতিদিনের উপস্থিতির বিস্তারিত তথ্য দেখতে নিচের বাটনে ক্লিক করুন।</p>
        <button class="btn-p" style="background:var(--primary);" onclick="openTeacherAttendanceModal()"><i class="fas fa-calendar-check"></i> View My Detailed Attendance</button>
    </div>
    
    <div class="section-title">📈 Result Processing</div>
    <div class="card" style="padding: 20px;">
      <form action="https://script.google.com/macros/s/AKfycbxxo0od8ZzHy7WaNDUJybjjqcISZf5fJLIN2CG2KiTN3r5f5uyWLclcw-nj4ugrK7_t/exec" method="POST" target="_blank" style="margin:0;">
          <button type="submit" class="btn-p action-btn-large" style="background:#0288D1;">
              <i class="fas fa-poll-h"></i> Open Result Manager
          </button>
      </form>
    </div>

    <div class="section-title">🛠️ Manage My Content</div>
    <div id="manageBox"></div>
</div>

<div id="forgotModal" class="modal-overlay">
  <div class="modal-box">
    <h3 style="margin-top:0; color:var(--primary); font-size:24px;">Reset Password</h3>
    <p style="color:var(--text-muted); font-size:14px; margin-bottom:25px;">Verify your identity to reset security key</p>
    <div id="fpStep1">
      <input type="tel" id="fpPhone" placeholder="Registered Mobile Number">
      <div style="display:flex; gap:15px; margin-top:15px;">
        <button class="btn-p" style="background:var(--accent); margin:0;" onclick="requestOTP('sms')"><i class="fas fa-sms"></i> SMS OTP</button>
        <button class="btn-p" style="background:var(--primary); margin:0;" onclick="requestOTP('email')"><i class="fas fa-envelope"></i> Email OTP</button>
      </div>
    </div>
    <div id="fpStep2" style="display:none;">
      <input type="text" id="fpOTP" placeholder="Enter 6-digit OTP Code">
      <button class="btn-p btn-success" onclick="verifyOTP()">Verify Code</button>
    </div>
    <div id="fpStep3" style="display:none;">
      <input type="password" id="fpNewPass" placeholder="New Password (Min. 6 chars)">
      <button class="btn-p" onclick="saveNewPassword()">Save Password</button>
    </div>
    <p id="fpMsg" style="font-size:14px; font-weight:700; margin-top:15px;"></p>
    <button class="close-modal-btn" onclick="closeForgotModal()">Cancel</button>
  </div>
</div>

<div id="delModal" class="modal-overlay">
  <div class="modal-box danger-modal">
    <h3 style="color:var(--danger); margin-top:0; font-size:22px;"><i class="fas fa-exclamation-triangle"></i> Confirm Deletion</h3>
    <p style="font-size:15px; color:#475569; font-weight:500;">Are you sure? This will permanently remove the post and any linked files from the server.</p>
    <button id="modalLink" class="btn-p" style="background:var(--danger); margin-top:20px;">Yes, Delete Permanently</button>
    <button class="close-modal-btn" onclick="closeDeleteModal()">Cancel</button>
  </div>
</div>

<div id="attendanceModal" class="modal-overlay">
    <div class="modal-box" style="max-width: 650px; padding: 30px;">
        <h3 style="margin:0 0 20px 0; color:var(--text-main); font-size:20px; border-bottom:2px solid #f1f5f9; padding-bottom:15px; text-align:left;">📅 My Attendance Logs</h3>
        
        <div style="margin-bottom: 15px;">
            <select id="attMonthFilter" onchange="renderTeacherAttendanceTable()" style="width:100%; padding: 12px; border-radius: 8px; border: 2px solid #e2e8f0; outline:none; font-family:inherit; font-weight:600; color:var(--text-main); cursor:pointer;">
