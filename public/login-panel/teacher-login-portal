  async function login() {
    let p = sanitizeHTML(document.getElementById('lPh').value.trim());
    let s = document.getElementById('lPs').value.trim();
    const b = document.getElementById('lBtn');
    const err = document.getElementById('err');
    
    err.innerText = "";
    if(!p || !s) { err.innerText = "Please fill in all fields!"; return; }
    
    if (s.length > 0 && s.length < 6) s = s.padEnd(6, '0');
    
    b.innerHTML = '<span class="loader-spinner"></span> Authenticating...'; b.disabled = true;
    
    let ph = p;
    if (ph.startsWith('0')) ph = ph.substring(1); 

    try {
      let emailToTry = `0${ph}@srms.edu.bd`;
      try {
          await auth.signInWithEmailAndPassword(emailToTry, s);
      } catch(e1) {
          emailToTry = `${ph}@srms.edu.bd`;
          await auth.signInWithEmailAndPassword(emailToTry, s);
      }

      const token = await auth.currentUser.getIdToken();
      const res = await fetch(`${FIREBASE_DB_BASE}/Teachers?pageSize=1000`, {
          headers: { "Authorization": "Bearer " + token }
      });
      const data = await res.json();
      
      let foundName = "Teacher", teacherDocId = null, dbPhoneToSave = ph;

      if(data.documents) {
        for(let d of data.documents) {
            let f = d.fields || {};
            let dbPhone = f.phone ? f.phone.stringValue : "";
            if(dbPhone === ph || dbPhone === "0"+ph || dbPhone === "+880"+ph) {
                foundName = f.name ? f.name.stringValue : "Teacher";
                teacherDocId = d.name.split('/').pop(); 
                dbPhoneToSave = dbPhone; 
                break;
            }
        }
      }
          
      tPhone = ph;
      exactDbPhone = dbPhoneToSave;
      localStorage.setItem("srms_phone", ph);
      localStorage.setItem("srms_exact_phone", dbPhoneToSave);
      localStorage.setItem("srms_name", foundName);
      if(teacherDocId) localStorage.setItem("srms_teacher_id", teacherDocId); 
      
      document.getElementById('lPs').value = '';
      showDashboard(foundName);
      
    } catch(e) { 
        err.innerText = "Teacher account not found or invalid password!"; 
        b.innerHTML = "Secure Login ➔"; b.disabled = false; 
    }
  }

