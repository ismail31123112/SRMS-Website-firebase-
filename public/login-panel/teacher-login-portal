  function openTeacherAttendanceModal() {
      document.getElementById('attendanceModal').style.display = 'flex';
      fetchTeacherDetailedAttendance();
  }

  async function fetchTeacherDetailedAttendance() {
      document.getElementById('attLoader').style.display = 'block';
      document.getElementById('modalAttTableBody').innerHTML = '';
      
      try {
          const token = await auth.currentUser.getIdToken();
          const headers = { "Content-Type": "application/json", "Authorization": "Bearer " + token };
          
          const attReq = { 
              structuredQuery: { 
                  from: [{ collectionId: "AttendanceHistory" }], 
                  where: { fieldFilter: { field: { fieldPath: "studentID" }, op: "EQUAL", value: { stringValue: exactDbPhone } } },
                  limit: 2000
              } 
          };
          
          const [attRes, holRes] = await Promise.all([
              fetch(`${FIREBASE_DB_BASE}:runQuery`, { method: "POST", headers, body: JSON.stringify(attReq) }),
              fetch(`${FIREBASE_DB_BASE}/Holidays?pageSize=1000`, { headers })
          ]);
          
          const attData = await attRes.json();
          const holData = await holRes.json();
          
          allTeacherAttendance = {}; 
          if (attData && attData.length > 0 && attData[0].document) {
              attData.forEach(item => {
                  if(item.document && item.document.fields) {
                      let f = item.document.fields;
                      let pDate = sanitizeHTML(f.pureDate?.stringValue || ""); 
                      let timeStr = sanitizeHTML(f.time?.stringValue || "");
                      let type = sanitizeHTML(f.type?.stringValue || ""); 
                      
                      if(pDate) {
                          if(!allTeacherAttendance[pDate]) { allTeacherAttendance[pDate] = { in: "-", out: "-" }; }
                          if(type === "IN") allTeacherAttendance[pDate].in = timeStr;
                          if(type === "OUT") allTeacherAttendance[pDate].out = timeStr;
                      }
                  }
              });
          }

          allHolidays = {};
          if(holData && holData.documents) {
              holData.documents.forEach(doc => {
                  let f = doc.fields;
                  let pDate = f.date?.stringValue;
                  let reason = f.reason?.stringValue || "Holiday";
                  if(pDate) allHolidays[pDate] = reason;
              });
          }

          populateTeacherAttendanceMonths();
      } catch(e) {
          console.error(e);
          document.getElementById('modalAttTableBody').innerHTML = '<tr><td colspan="4" style="text-align:center; padding:15px; color:var(--danger); font-weight:bold;">Failed to synchronize attendance data.</td></tr>';
      }
      document.getElementById('attLoader').style.display = 'none';
  }

  function populateTeacherAttendanceMonths() {
      let select = document.getElementById('attMonthFilter');
      select.innerHTML = "";
      
      const bdTime = new Date().toLocaleString("en-US", {timeZone: "Asia/Dhaka"});
      const now = new Date(bdTime);
      
      let months = [];
      for(let i=0; i<12; i++) {
          let d = new Date(now.getFullYear(), now.getMonth() - i, 1);
          let mStr = d.getFullYear() + "-" + String(d.getMonth()+1).padStart(2, '0');
          months.push(mStr);
      }
      
      months.forEach(m => {
          let dateObj = new Date(m + "-01");
          let monthName = dateObj.toLocaleString('default', { month: 'long', year: 'numeric' });
          select.innerHTML += `<option value='${m}'>${monthName}</option>`;
      });
      
      renderTeacherAttendanceTable(months[0]);
  }

  function renderTeacherAttendanceTable(selectedMonth = null) {
      if(!selectedMonth) selectedMonth = document.getElementById('attMonthFilter').value;
      let tbody = document.getElementById('modalAttTableBody');
      let summaryBox = document.getElementById('modalAttSummary');
      let yearlySummaryBox = document.getElementById('modalYearlySummary');
      
      // Bangladesh Time Logic
      const bdTime = new Date().toLocaleString("en-US", {timeZone: "Asia/Dhaka"});
      const today = new Date(bdTime);
      
      let dateParts = selectedMonth.split('-');
      let sYear = parseInt(dateParts[0]);
      let sMonth = parseInt(dateParts[1]);
      
      let daysInMonth = new Date(sYear, sMonth, 0).getDate();
      let daysToLoop = daysInMonth;
      
      if(sYear > today.getFullYear() || (sYear === today.getFullYear() && sMonth > today.getMonth() + 1)) {
           tbody.innerHTML = '<tr><td colspan="4" style="text-align:center; padding:30px; color:#64748b; font-weight:600;">No attendance records for future months.</td></tr>';
           summaryBox.style.display = 'none';
           yearlySummaryBox.style.display = 'none';
           return;
      }
      
      if(sYear === today.getFullYear() && sMonth === today.getMonth() + 1) {
           daysToLoop = today.getDate();
      }

      // Yearly Calculation 
      let isYearFinished = (sYear < today.getFullYear());
      if (!isYearFinished) {
          yearlySummaryBox.style.display = 'none';
          yearlySummaryBox.innerHTML = '';
      } else {
          let yearlyPresentCount = 0;
          let yearlyAbsentCount = 0;

          for(let m = 1; m <= 12; m++) {
              let mStr = sYear + "-" + String(m).padStart(2, '0');
              let mPresent = 0;
              let mHoliday = 0;
              let daysInM = new Date(sYear, m, 0).getDate();

              for(let d=1; d<=daysInM; d++) {
                  let dStr = String(d).padStart(2, '0');
                  let fDate = `${mStr}-${dStr}`;
                  if(allTeacherAttendance[fDate]) mPresent++;
                  else if(allHolidays[fDate]) mHoliday++;
              }

              yearlyPresentCount += mPresent;
              let workingDaysInM = Math.max(mPresent, daysInM - mHoliday - 4); // General estimation
              let mAbsent = Math.max(0, workingDaysInM - mPresent);
              yearlyAbsentCount += mAbsent;
          }

          yearlySummaryBox.style.display = 'block';
          yearlySummaryBox.innerHTML = `Yearly Total (<span style="color:var(--accent);">${sYear}</span>): <span style="font-size: 18px;">${yearlyPresentCount} Days Present</span> <span style="opacity:0.5; margin:0 10px;">|</span> <span style="color:#fecdd3; font-size:18px;">~${yearlyAbsentCount} Days Absent</span>`;
      }

      let presentCount = 0; let absentCount = 0; let holidayCount = 0;
      let html = "";
      
      for(let d = daysToLoop; d >= 1; d--) {
           let dStr = String(d).padStart(2, '0');
           let fullDate = `${sYear}-${String(sMonth).padStart(2, '0')}-${dStr}`;
           
           let statusHtml = ""; let inTime = "-"; let outTime = "-"; let bgRow = "";
           
           if(allHolidays[fullDate]) {
               statusHtml = `<span style="color:var(--warning); font-weight:800; font-size:12px;">⛱️ ${sanitizeHTML(allHolidays[fullDate])}</span>`;
               holidayCount++;
               bgRow = "background: #fffbeb;";
           } else if (allTeacherAttendance[fullDate]) {
               let rec = allTeacherAttendance[fullDate];
               inTime = rec.in; outTime = rec.out;
               statusHtml = `<span style="color:var(--success); font-weight:800; font-size:12px;">✅ PRESENT</span>`;
               presentCount++;
           } else {
               statusHtml = `<span style="color:var(--danger); font-weight:800; font-size:12px;">❌ ABSENT</span>`;
               absentCount++;
               bgRow = "background: #fff1f2;";
           }
           
           html += `
            <tr style="border-bottom: 1px solid #f1f5f9; transition: 0.2s; ${bgRow}">
                <td style="padding: 12px 15px; font-weight:700; color:var(--text-main); font-size:13px;">${fullDate}</td>
                <td style="padding: 12px 15px;">${statusHtml}</td>
                <td style="padding: 12px 15px; color:#059669; font-weight:700; font-size:12px;">${inTime}</td>
                <td style="padding: 12px 15px; color:#e11d48; font-weight:700; font-size:12px;">${outTime}</td>
            </tr>`;
      }
      
      if(html === "") {
           tbody.innerHTML = '<tr><td colspan="4" style="text-align:center; padding:30px; color:#64748b; font-weight:600;">No attendance records available.</td></tr>';
           summaryBox.style.display = 'none';
      } else {
           tbody.innerHTML = html;
           summaryBox.style.display = 'flex';
           summaryBox.innerHTML = `
            <span style="display:flex; flex-direction:column; align-items:center;">
                <small style="color:#64748b; font-size:11px; text-transform:uppercase;">Present</small>
                <span style="font-size:18px; color:var(--success); font-weight:900;">${presentCount}</span>
            </span>
            <span style="display:flex; flex-direction:column; align-items:center;">
                <small style="color:#64748b; font-size:11px; text-transform:uppercase;">Absent</small>
                <span style="font-size:18px; color:var(--danger); font-weight:900;">${absentCount}</span>
            </span>
            <span style="display:flex; flex-direction:column; align-items:center;">
                <small style="color:#64748b; font-size:11px; text-transform:uppercase;">Holidays</small>
                <span style="font-size:18px; color:var(--warning); font-weight:900;">${holidayCount}</span>
            </span>
        `;
      }
  }
</script>
</body>
</html>
