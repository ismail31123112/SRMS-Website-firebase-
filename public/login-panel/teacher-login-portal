            </select>
        </div>
        
        <div id="attLoader" style="text-align:center; color:var(--primary); font-weight:bold; display:none; padding:20px 0;">
            <span class="loader-spinner" style="border-top-color:var(--primary);"></span> Synchronizing Database...
        </div>

        <div id="modalYearlySummary" style="margin-bottom:15px; font-weight:700; color:#fff; padding:15px; background:linear-gradient(135deg, var(--primary), var(--primary-dark)); border-radius:12px; text-align:center; box-shadow: 0 5px 15px rgba(0,95,64,0.2); display: none;">
        </div>
        
        <div style="max-height: 350px; overflow-y: auto; border: 1px solid #e2e8f0; border-radius: 12px; background: #f8fafc; text-align:left;">
            <table style="width:100%; border-collapse: collapse; font-size: 13px;">
                <thead style="background: #e2e8f0; position: sticky; top: 0; z-index: 10;">
                    <tr>
                        <th style="padding: 12px 15px; color:#475569; border-bottom: 2px solid #cbd5e1;">Date (Y-M-D)</th>
                        <th style="padding: 12px 15px; color:#475569; border-bottom: 2px solid #cbd5e1;">Status</th>
                        <th style="padding: 12px 15px; color:#475569; border-bottom: 2px solid #cbd5e1;">IN Time</th>
                        <th style="padding: 12px 15px; color:#475569; border-bottom: 2px solid #cbd5e1;">OUT Time</th>
                    </tr>
                </thead>
                <tbody id="modalAttTableBody" style="background: white;">
                </tbody>
            </table>
        </div>
        
        <div id="modalAttSummary" style="margin-top:20px; font-weight:800; color:var(--primary); padding:15px; background:#f0fdf4; border-radius:12px; display: none; justify-content: space-around; border: 1px solid #bbf7d0;">
        </div>
        <button class="close-modal-btn" onclick="closeModal('attendanceModal')" style="margin-top:20px;">Close Logs</button>
    </div>
</div>

<footer class="premium-footer" id="main-footer">
  <h3 style="margin:0 0 5px 0; color:#fff; font-size:18px;">SRMS</h3>
  <p style="margin:0; opacity:0.7; font-size:14px;">Saidpur Residential Model School<br>Saidpur, Nilphamari.</p>
  <p style="margin:20px 0 0 0; font-size:12px; color:#64748b; border-top:1px solid #1e293b; padding-top:15px;">© 2026 SRMS. Secure Academic Portal.</p>
</footer>

