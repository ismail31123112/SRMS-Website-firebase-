<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Educator Dashboard | SRMS</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;800&display=swap" rel="stylesheet">
<style>
  body { font-family: 'Poppins', sans-serif; background: #eef2f6; text-align: center; margin: 0; padding: 20px; display: flex; justify-content: center; align-items: center; min-height: 90vh; }
  .card { background: white; width: 100%; max-width: 480px; padding: 35px 30px; border-radius: 20px; box-shadow: 0 20px 40px rgba(0,0,0,0.08); border-top: 6px solid #b45309; }
  .header-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
  .school-name { font-size: 13px; color: #b45309; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; }
  .home-btn { background: #fef3c7; color: #b45309; padding: 6px 12px; border-radius: 6px; font-size: 12px; font-weight: bold; text-decoration: none; border: 1px solid #fde68a; transition: 0.3s; }
  .home-btn:hover { background: #b45309; color: white; }
  h2 { color: #1e293b; margin: 0 0 20px 0; font-weight: 800; font-size: 26px; }
  
  input, select { width: 100%; padding: 14px; margin-bottom: 15px; border-radius: 10px; border: 1.5px solid #e2e8f0; font-family: inherit; font-size: 15px; background: #f8fafc; transition: 0.3s; box-sizing: border-box; }
  input:focus, select:focus { border-color: #b45309; outline: none; box-shadow: 0 0 0 3px rgba(180, 83, 9, 0.1); background: white; }
  .btn-start { background: linear-gradient(135deg, #b45309, #d97706); color: white; padding: 16px; border: none; border-radius: 10px; width: 100%; font-weight: 700; font-size: 16px; cursor: pointer; text-transform: uppercase; letter-spacing: 1px; transition: 0.3s; box-shadow: 0 10px 20px rgba(180, 83, 9, 0.2); }
  .btn-start:hover { transform: translateY(-2px); box-shadow: 0 15px 25px rgba(180, 83, 9, 0.3); }
  .btn-start:disabled { background: #9ca3af; cursor: not-allowed; box-shadow: none; transform: none; }
  
  .instructions { color: #b45309; font-size: 13px; font-weight: 500; margin-bottom: 20px; background: #fffbeb; padding: 12px; border-radius: 8px; border: 1px solid #fde68a; text-align: left; line-height: 1.5; }
  .active-list-container { margin-top: 30px; display: none; animation: fadeIn 0.5s; }
  .active-list-title { color:#15803d; margin:0 0 15px 0; font-size:18px; font-weight:800; border-bottom: 2px solid #bbf7d0; padding-bottom:10px; text-align: left; }
  .info-panel { background: #f0fdf4; padding: 20px; border-radius: 15px; text-align: left; margin-bottom: 15px; border: 2px solid #bbf7d0; position: relative; transition: all 0.3s; }
  .info-panel p { margin: 5px 0; font-size: 15px; color: #005f40; }
  .btn-stop { background: #dc2626; color: white; padding: 12px; border: none; border-radius: 8px; width: 100%; font-weight: 700; font-size: 14px; cursor: pointer; transition: 0.3s; margin-top: 10px; box-shadow: 0 5px 15px rgba(220, 38, 38, 0.2); display: flex; justify-content: center; align-items: center; gap: 8px; }
  .btn-stop:hover { background: #b91c1c; }
  .btn-stop:disabled { background: #fca5a5; cursor: not-allowed; box-shadow: none; }
  .spinner-small { width: 16px; height: 16px; border: 3px solid rgba(255,255,255,0.3); border-top: 3px solid white; border-radius: 50%; animation: spin 0.8s linear infinite; display: inline-block; }
  
  @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
</style>
</head>
<body>

<div class="card">
  <div class="header-top">
    <div class="school-name">Saidpur Residential Model School</div>
    <a href="https://www.saidpurresidentialmodelschool.com/home" target="_blank" class="home-btn">🏠 Home</a>
  </div>
  <img src="https://i.postimg.cc/hGQQqrsb/20260117_231551.png" width="70" alt="Logo" style="margin-bottom: 10px;">
  <h2>Educator Live Dashboard</h2>
  
  <div id="form-area">
    <div class="instructions">
       <b>💡 নির্দেশনা:</b> লাইভ ক্লাস শুরু করার পর যে লিংকটি ওপেন হবে, সেখানে অবশ্যই <b>'Join in Browser'</b> অপশনে ক্লিক করে ক্লাসে যুক্ত হবেন।
    </div>
    
    <input type="text" id="tName" placeholder="শিক্ষকের নাম">
    <input type="text" id="tSub" placeholder="মিটিং এর বিষয় (যেমন: গণিত, অধ্যায়-২)">
    <input type="hidden" id="tPic" value="https://i.postimg.cc/hGQQqrsb/20260117_231551.png">
    
    <select id="tClass">
        <optgroup label="Primary/Junior">
          <option value="Play">Class Play</option><option value="Nursery">Nursery</option><option value="KG">Class KG</option>
          <option value="1">Class 1</option><option value="2">Class 2</option><option value="3">Class 3</option><option value="4">Class 4</option>
          <option value="5">Class 5</option><option value="6">Class 6</option><option value="7">Class 7</option><option value="8">Class 8</option>
        </optgroup>
        <optgroup label="Secondary">
          <option value="9-Science">9 (Science)</option><option value="9-Arts">9 (Arts)</option><option value="9-Commerce">9 (Commerce)</option>
          <option value="10-Science">10 (Science)</option><option value="10-Arts">10 (Arts)</option><option value="10-Commerce">10 (Commerce)</option>
        </optgroup>
        <option value="Guardian">Guardian Meeting</option><option value="All">All School Meeting</option>
    </select>
    
    <button class="btn-start" id="startBtn">START LIVE BROADCAST 🚀</button>
  </div>
  
  <div id="activeListArea" class="active-list-container">
      <h3 class="active-list-title">✅ চলমান লাইভ সেশনসমূহ</h3>
      <div id="sessionsContainer"></div>
  </div>
</div>

<script>
// ⚠️ এখানে আপনার কপি করা নতুন Web App URL টা বসিয়ে দিন:
const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbxaayPCwfdZvXSXJPdzPspPmAeH72-NAvqGJIbuhwid3T28imRxNRypPI9m1bJQrfqLhg/exec'; 

window.onload = function() { loadActiveSessions(); };

async function loadActiveSessions() {
    const listDiv = document.getElementById('activeListArea');
    const container = document.getElementById('sessionsContainer');
    listDiv.style.display = 'block';
    container.innerHTML = '<p style="color:#b45309; font-weight:bold; text-align:center;">⏳ সেশন চেক করা হচ্ছে...</p>';

    try {
        const res = await fetch(SCRIPT_URL + '?action=getAll');
        const textResponse = await res.text();
        
        let json;
        try {
            json = JSON.parse(textResponse);
        } catch (e) {
            container.innerHTML = '<p style="color:red; font-weight:bold;">❌ Error: ডেপ্লয়মেন্টে Anyone পারমিশন দিন।</p>';
            return;
        }

        const docs = json.documents || [];
        let html = '';
        let hasActive = false;
        const classSelect = document.getElementById('tClass');

        docs.forEach(d => {
            let f = d.fields || {};
            let docName = d.name.split("/").pop(); 
            
            if (f.status && f.status.stringValue === 'TRUE') {
                hasActive = true;
                let title = f.title ? f.title.stringValue : "None";
                let opt = Array.from(classSelect.options).find(o => o.value === docName);
                let label = opt ? opt.text : docName;

                html += `
                <div class="info-panel">
                   <p><b>মিটিংয়ের ধরন:</b> ${label}</p>
                   <p style="margin-bottom:15px;"><b>বিষয়:</b> ${title}</p>
                   <button class="btn-stop" onclick="endSpecificSession('${docName}', '${title}', this)">🔴 END SESSION</button>
                </div>`;
            }
        });

        if(hasActive) {
            container.innerHTML = html;
        } else {
            listDiv.style.display = 'none'; 
            container.innerHTML = '';
        }
    } catch(e) {
        container.innerHTML = '<p style="color:red; font-weight:bold;">সার্ভার কানেকশন এরর!</p>';
    }
}

document.getElementById('startBtn').addEventListener('click', async function() {
    const sClass = document.getElementById('tClass').value;
    const name = document.getElementById('tName').value;
    const sub = document.getElementById('tSub').value;
    const pic = document.getElementById('tPic').value;
    
    if(!name || !sub) return alert("অনুগ্রহ করে শিক্ষক এবং বিষয়ের নাম দিন!");
    
    const btn = document.getElementById('startBtn');
    btn.innerHTML = '<span class="spinner-small"></span> Processing...';
    btn.disabled = true;

    const config = `#config.prejoinPageEnabled=false&userInfo.displayName="${name} (Teacher)"&userInfo.avatarUrl="${encodeURIComponent(pic)}"&interfaceConfig.TOOLBAR_BUTTONS=["microphone","camera","desktop","chat","raisehand","mute-everyone","security","tileview","fullscreen","hangup","settings","recording","livestreaming"]`;
    window.open(`https://meet.jit.si/SRMS-Live-${sClass}${config}`, '_blank');
    
    try {
        await fetch(SCRIPT_URL, { method: 'POST', mode: 'no-cors', body: JSON.stringify({ action: "update", className: sClass, status: "TRUE", title: sub }) });
    } catch(err) {}
    
    document.getElementById('tSub').value = ''; 
    btn.innerHTML = 'START LIVE BROADCAST 🚀';
    btn.disabled = false;
    setTimeout(loadActiveSessions, 1500);
});

async function endSpecificSession(sClass, sub, btnElement) {
    const panel = btnElement.parentElement;
    btnElement.innerHTML = '<span class="spinner-small"></span> বন্ধ করা হচ্ছে...';
    btnElement.disabled = true;

    try {
        await fetch(SCRIPT_URL, { method: 'POST', mode: 'no-cors', body: JSON.stringify({ action: "update", className: sClass, status: "FALSE", title: sub }) });
        await new Promise(r => setTimeout(r, 800));
        
        panel.style.border = "2px solid #fecaca";
        panel.style.background = "#fef2f2";
        panel.innerHTML = `<h3 style="color:#b91c1c; margin:0;">✅ সাকসেস!</h3><p style="color:#b91c1c; margin:5px 0;">"${sub}" সেশনটি বন্ধ করা হয়েছে।</p>`;
        
        setTimeout(loadActiveSessions, 2000);
    } catch (error) {
        btnElement.innerHTML = '🔴 END SESSION';
        btnElement.disabled = false;
    }
}
</script>
</body>
</html>
